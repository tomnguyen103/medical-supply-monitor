# This foundation pulls in many independent integrations (Clerk, Sentry,
# LangChain, Drizzle, Inngest, Upstash) whose transitive peer-dependency ranges
# do not always intersect cleanly. legacy-peer-deps keeps installs deterministic
# instead of failing on benign peer mismatches. Revisit per-package if a real
# incompatibility surfaces.
legacy-peer-deps=true
save-exact=false
