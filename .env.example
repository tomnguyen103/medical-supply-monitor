# =============================================================================
# Critical Medical Supply Resilience Monitor — environment template
# -----------------------------------------------------------------------------
# Copy to `.env.local` and fill in the values you need. EVERY integration is
# OPTIONAL at boot: with no values set, the app runs in a "not configured" mode
# (landing page + setup status render; protected/data features stay disabled).
# Provide a key to switch that integration on.
#
# NEVER commit `.env.local` or real secrets. No PHI, no patient data anywhere.
# =============================================================================

# --- App -------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Clerk (auth + organizations / tenancy) --------------------------------
# https://dashboard.clerk.com -> API keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/dashboard"

# --- Neon Postgres (Drizzle ORM) -------------------------------------------
# https://console.neon.tech -> Connection string (pooled, sslmode=require)
DATABASE_URL=""

# --- Upstash Redis (cache, rate limits, alert cooldowns) -------------------
# https://console.upstash.com -> REST API
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Inngest (background ingestion / scoring / alert jobs) ------------------
# https://app.inngest.com -> Manage -> Event/Signing keys
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# --- Sentry (error monitoring) ---------------------------------------------
# https://sentry.io -> Project settings -> Client keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""          # only needed to upload source maps at build time

# --- LangSmith + LangChain (AI workflows: tracing / evals) -----------------
# https://smith.langchain.com -> Settings -> API keys
LANGSMITH_TRACING="false"
LANGSMITH_API_KEY=""
LANGSMITH_PROJECT="medical-supply-monitor"
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
# Default model provider for LangGraph agents (Anthropic recommended).
ANTHROPIC_API_KEY=""
# OPENAI_API_KEY=""           # optional alternate provider

# --- Notifications (Phase 5; placeholders for now) -------------------------
RESEND_API_KEY=""
ALERT_FROM_EMAIL="alerts@example.com"
SLACK_WEBHOOK_URL=""

# --- Risk data connectors (Phase 3) ----------------------------------------
# Most public feeds (openFDA, USGS, NWS, GDELT, CISA KEV, OFAC) need no key.
# NWS requires a descriptive User-Agent per their API policy.
RISK_FEED_USER_AGENT="medical-supply-monitor (contact: ops@example.com)"
NASA_FIRMS_MAP_KEY=""         # https://firms.modaps.eosdis.nasa.gov/api/
# WorldMonitor is OPTIONAL enrichment only — the product must run without it.
WORLDMONITOR_API_BASE_URL=""
WORLDMONITOR_API_KEY=""

# --- Product analytics (optional, privacy-restricted) ----------------------
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
